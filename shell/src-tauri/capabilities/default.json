{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities — all webviews can use core IPC, events, and Quill commands.",
  "windows": ["main", "overlay"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "core:window:default",
    "core:webview:default",
    "core:app:default"
  ]
}
