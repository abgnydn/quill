{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nib",
  "version": "1.0.6",
  "identifier": "app.nib",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Nib",
        "label": "main",
        "width": 920,
        "height": 640,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true,
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/lfm2.5-350m-q4_k_m.gguf",
      "resources/qvac/*"
    ],
    "category": "Productivity",
    "shortDescription": "Nib — local-first grammar assistant",
    "longDescription": "Nib is a local-first grammar and writing assistant for macOS. Combines a fast Harper rule engine with the LiquidAI LFM2.5-350M LLM, both running entirely on-device. Zero network calls; your prose never leaves your Mac.",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "frameworks": [],
      "signingIdentity": "-",
      "infoPlist": "Info.plist"
    }
  }
}
